{
  "name": "@wave-client/shared",
  "version": "0.0.1",
  "license": "SEE LICENSE IN LICENSE",
  "description": "Shared services for Wave Client - used by both VS Code extension and server",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@wave-client/core": "workspace:*",
    "ajv": "^8.18.0",
    "axios": "^1.14.0",
    "jsonpath-plus": "^10.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist",
    "src"
  ]
}
