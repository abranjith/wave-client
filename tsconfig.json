{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022",
			"DOM"
		],
		"sourceMap": true,
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true
	},
	"files": [],
	"exclude": [
		"node_modules",
		"out",
		"dist",
		"**/node_modules",
		"**/dist",
		"packages"
	]
}
